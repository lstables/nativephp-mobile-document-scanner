{
    "name": "lstables/nativephp-mobile-document-scanner",
    "description": "Document scanning plugin for NativePHP Mobile",
    "type": "nativephp-plugin",
    "license": "MIT",
    "keywords": [
        "nativephp",
        "mobile",
        "document-scanner",
        "visionkit",
        "mlkit",
        "pdf",
        "ocr"
    ],
    "authors": [
        {
            "name": "Lee Stables",
            "email": "lstables1@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^2.0|^3.0"
    },
    "autoload": {
        "psr-4": {
            "lstables\\NativeDocumentScanner\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "lstables\\NativeDocumentScanner\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "lstables\\NativeDocumentScanner\\DocumentScannerServiceProvider"
            ]
        },
        "nativephp": {
            "manifest": "nativephp.json"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
